{{define "formula_install" -}}
bin.install "{{bin_name .}}"
{{- end}}

{{define "formula_test" -}}
assert_match(/Driver:.*{{.}}/, shell_output("#{bin}/{{bin_name .}} version 2>&1"))
{{- end}}

{{define "formula" -}}
class {{.ClassName}} < Formula
  {{$num_drivers := len .Drivers -}}
  {{$desc := printf "Database migrations CLIs for %s" (join .Drivers ", ") -}}
  {{if eq $num_drivers 1 -}}
  {{$desc = printf "Database migrations CLI for %s" (index .Drivers 0) -}}
  {{end -}}
  desc "{{$desc}}"
  homepage "https://github.com/rafaelespinoza/godfish"
  version "{{.Version}}"
  license "ISC"
  {{if eq $num_drivers 1 -}}
  {{$name_of_bin := bin_name (index .Drivers 0) -}}
  {{$reason := printf "the godfish formula already install the binary, %s" $name_of_bin -}}
  conflicts_with "godfish", because: "{{$reason}}"
  {{- else -}}
  {{$driver_formulae_names := quote_conflicting_formulae .Drivers -}}
  conflicts_with(
    {{join $driver_formulae_names ",\n    "}},
    because: "each driver formula (godfish_*) already installs a binary of the same name",
  )
  {{- end}}

  if OS.mac? && Hardware::CPU.intel?
    {{$release := .ReleaseAssets.MacOSIntel -}}
    url "{{$release.URL}}"
    sha256 "{{$release.SHA256}}"
  end

  if OS.mac? && Hardware::CPU.arm?
    {{$release := .ReleaseAssets.MacOSARM -}}
    url "{{$release.URL}}"
    sha256 "{{$release.SHA256}}"
  end

  if OS.linux? && Hardware::CPU.intel?
    {{$release := .ReleaseAssets.LinuxIntel -}}
    url "{{$release.URL}}"
    sha256 "{{$release.SHA256}}"
  end

  if OS.linux? && Hardware::CPU.arm?
    {{$release := .ReleaseAssets.LinuxARM -}}
    url "{{$release.URL}}"
    sha256 "{{$release.SHA256}}"
  end
  {{- /*
  # TODO: figure out how to detect a Windows-like platform for Homebrew.
  # if OS.wsl? && Hardware::CPU.intel?
  #   {{$release := .ReleaseAssets.WSLIntel -}}
  #   url "{{$release.URL}}"
  #   sha256 "{{$release.SHA256}}"
  # end

  # if OS.wsl? && Hardware::CPU.arm?
  #   {{$release := .ReleaseAssets.WSLARM -}}
  #   url "{{$release.URL}}"
  #   sha256 "{{$release.SHA256}}"
  # end
  */}}

  def install
    # Homebrew extracts the entire multi-binary archive. Cherry-pick only
    # the targeted binaries into the installation path
    {{- range .Drivers}}
    {{template "formula_install" .}}
    {{- end}}
  end

  test do
    {{- range .Drivers}}
    {{template "formula_test" .}}
    {{- end}}
  end
end
{{end}}
